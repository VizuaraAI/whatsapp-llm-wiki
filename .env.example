# Required for LLM-generated wiki updates.
OPENAI_API_KEY=

# Pick a current small/fast OpenAI model you have access to.
OPENAI_MODEL=gpt-4o-mini

# Comma-separated WhatsApp group JIDs to ingest, e.g. 1203630xxxxx@g.us.
# Leave empty only while discovering group IDs.
WHATSAPP_GROUP_JIDS=

# If true, ingest every WhatsApp group visible to the linked number.
# Recommended only when using a dedicated workshop number.
INGEST_ALL_GROUPS=false

# Download media/documents shared in watched groups.
DOWNLOAD_MEDIA=true

# Number of newest messages to consider during each wiki refresh.
WIKI_BATCH_SIZE=250

# Automatically regenerate wiki pages while the WhatsApp listener runs.
AUTO_UPDATE_WIKI=true
WIKI_UPDATE_EVERY_MESSAGES=20
